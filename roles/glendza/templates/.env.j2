# Glendza Environment Configuration
# This file is populated from Ansible vault variables

# Django settings:
GLENDZA__CSRF_TRUSTED_ORIGINS={{ glendza_csrf_trusted_origins }}
GLENDZA__DEBUG={{ glendza_debug }}
GLENDZA__SECRET_KEY={{ glendza_secret_key }}
GLENDZA__ALLOWED_HOSTS={{ glendza_allowed_hosts }}

# Logging settings:
GLENDZA__LOG_LEVEL={{ glendza_log_level }}
GLENDZA__LOG_LOCATION=/app/logs

# Static files settings:
GLENDZA__STATIC_URL={{ glendza_static_url }}
GLENDZA__STATIC_ROOT=/app/static

# Media files settings:
GLENDZA__MEDIA_URL={{ glendza_media_url }}
GLENDZA__MEDIA_ROOT=/app/data/media

# Database settings:
GLENDZA__DB_LOCATION={{ glendza_db_location }}

# Admin routes:
GLENDZA__DJANGO_ADMIN_URL={{ glendza_django_admin_url }}
GLENDZA__WAGTAIL_ADMIN_URL={{ glendza_wagtail_admin_url }}

# Email settings:
GLENDZA__EMAIL_BACKEND={{ glendza_email_backend }}
GLENDZA__EMAIL_HOST={{ glendza_email_host }}
GLENDZA__EMAIL_PORT={{ glendza_email_port }}
GLENDZA__EMAIL_USE_TLS={{ glendza_email_use_tls }}
GLENDZA__EMAIL_HOST_USER={{ glendza_email_host_user }}
GLENDZA__EMAIL_HOST_PASSWORD={{ glendza_email_host_password }}
GLENDZA__EMAIL_USE_SSL={{ glendza_email_use_ssl }}

# Recaptcha settings:
GLENDZA__RECAPTCHA_PUBLIC_KEY={{ glendza_recaptcha_public_key }}
GLENDZA__RECAPTCHA_PRIVATE_KEY={{ glendza_recaptcha_private_key }}
