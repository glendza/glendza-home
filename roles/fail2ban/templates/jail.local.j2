[DEFAULT]
bantime  = {{ fail2ban_bantime }}
findtime = {{ fail2ban_findtime }}
maxretry = {{ fail2ban_maxretry }}
backend  = {{ fail2ban_backend }}
ignoreip = {{ fail2ban_ignoreip }}

# Generated by Ansible fail2ban role
# Services configured: {{ fail2ban_services | length if fail2ban_services else 0 }}

{% if fail2ban_services and fail2ban_services | length > 0 %}
{% for service_name, service_config in fail2ban_services.items() %}
[{{ service_name }}]
enabled  = {{ 'true' if service_config.enabled else 'false' }}
port     = {{ service_config.port }}
filter   = {{ service_config.filter }}
backend  = {{ service_config.backend if service_config.backend is defined else fail2ban_backend }}
logpath  = {{ service_config.logpath }}
maxretry = {{ service_config.maxretry }}
{% if service_config.action is defined %}
action = {{ service_config.action }}
{% endif %}
{% if service_config.banaction is defined %}
banaction = {{ service_config.banaction }}
{% endif %}
{% endfor %}
{% else %}
# No services configured - jail.local will be empty
# This usually means fail2ban_services variable is not defined or empty
{% endif %}
